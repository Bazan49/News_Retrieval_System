# Ejemplo de archivo de configuración de entorno.
# Copia este archivo como `.env` y rellena los valores según tu entorno.

# --------------------------------------------------
# Configuración de ElasticSearch
# --------------------------------------------------
# URL(s) de tus nodos de ElasticSearch (pueden ser múltiples, separadas por comas).
# - En desarrollo local con Docker suele ser: https://localhost:9200
# - Si usas un cluster, puedes incluir varios hosts.
ELASTICSEARCH_HOSTS=["https://localhost:9200"]

# Usuario y contraseña para autenticar contra ElasticSearch.
# Asegúrate de que el usuario exista y tenga permisos para crear índices y escribir.
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=TU_PASSWORD_AQUI

# Nombre del índice donde se almacenarán los documentos.
# Cambia esto si deseas tener varios índices (por ejemplo: scraped-docs-v2).
INDEX_NAME=scraped-docs

# --------------------------------------------------
# Configuración de ChromaDB (modo servidor)
# --------------------------------------------------
# Host y puerto donde corre el servidor ChromaDB.
# Si usas el contenedor oficial, el puerto por defecto es 8000, pero puedes cambiarlo si lo necesitas.
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Nombre de la colección de vectores donde se guardarán los embeddings de los documentos.
CHROMA_COLLECTION=news_embeddings

# --------------------------------------------------
# Configuración del modelo de embeddings
# --------------------------------------------------

# Modelo de sentence-transformers (Jina, optimizado para español)
EMBEDDING_MODEL=jinaai/jina-embeddings-v2-base-es

# Longitud máxima de contexto del modelo (en tokens)
MODEL_MAX_SEQ_LEN=8192

# Backend opcional (onnx / None). Jina soporta ONNX oficialmente.
EMBEDDING_BACKEND=onnx

# --------------------------------------------------
# Configuración del chunking
# --------------------------------------------------
# Tamaño máximo de cada chunk en tokens (debe ser <= MODEL_MAX_SEQ_LEN - 2)
CHUNKER_MAX_TOKENS=1024   # Puedes ajustarlo según tus necesidades y el modelo. 1024 es un buen punto de partida para modelos grandes.

# Solapamiento entre chunks. Se expresa como porcentaje del tamaño del chunk (ej: 15% de 1024 = 153 tokens de solapamiento).
OVERLAP_PERCENT=15